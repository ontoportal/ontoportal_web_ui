- if fairness_service_enabled? && @ontology.acronym != 'AGROVOC' && @fair_scores_data
  = render SummarySectionComponent.new(title: t("ontologies.sections.metadata.fair_score_title")) do |s|
    - s.action_link do
      = render partial: "fair_score/fair_service_header"

    %div.p-2
      %section.ont-metadata-card.ont-fair-score-card#fair-summary
        %div.ont-section-toolbar.justify-content-between.flex-row-reverse
          %div.align-items-start
            .btn.btn-primary.rounded-pill.right-button
              .span{ style: 'cursor: default;' }= t("ontologies.sections.metadata.total_score", score: @fair_scores_data[:score], normalized_score: @fair_scores_data[:normalizedScore])

      %div#fair-score-charts-container
        = render partial: "fairs_score"
      .account-page-card-sub-container

      - foops_res = get_foops_score(@ontology)
      - foops_data = parse_foops_data(foops_res)
      
      - if foops_data
        .foops-container.mt-4.p-4.rounded{ style: "background: #fff; border: 1px solid #d1d9e6; box-shadow: 0 4px 15px rgba(0,0,0,0.05);" }
          .d-flex.align-items-center.justify-content-between.mb-4.pb-3{ style: "border-bottom: 2px solid #e2e8f0;" }
            %div
              %h3.m-0{ style: "color: #2d3748; font-weight: 700;" }
                FOOPS! 
                %span{ style: "font-weight: 400; font-size: 0.7em; color: #718096;" } FAIRness Assessment
              .d-flex.align-items-baseline.mt-1
                %p.text-muted.small.m-0{ style: "max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;", title: foops_data[:metadata][:uri] }
                  = "Tested: #{foops_data[:metadata][:uri]}"
            
          #graphics.row.mt-3.justify-content-center
            #graphicScore.col-5.d-flex.align-items-center.justify-content-center{ "pointer-events": "all" }
              %svg{ height: "100", width: "100", transform: "scale(1.4,1.4)" }
                %circle{ cx: "50", cy: "50", r: "45", fill: "#FBFBFB" }
                %path{ fill: "none", "stroke-linecap": "round", "stroke-width": "5", stroke: "#E65A28", "stroke-dasharray": calculate_foops_gauge_dash(foops_data[:overall_score]), d: "M50 10 a 40 40 0 0 1 0 80 a 40 40 0 0 1 0 -80" }
                %text{ x: "50", y: "50", "text-anchor": "middle", dy: "7", "font-size": "24", "font-weight": "800", fill: "#2d3748" }= "#{foops_data[:overall_score].round}%"

            - spider_data = calculate_foops_spider_data(foops_data[:categories])
            #graphicSpider.col-6.d-flex.align-items-center.justify-content-center.pt-4{ "pointer-events": "all" }
              %svg{ height: "200", width: "250", viewBox: "-120 0 300 100", transform: "scale(1.6,1.6)" }

                / Diamond Grid Lines
                - [0.25, 0.5, 0.75].each do |level|
                  - up = 35 * level
                  - right = 34 * level
                  - down = 35 * level
                  - left = 35 * level
                  %path{ d: "M 57 #{50 - up} L #{57 + right} 50 L 57 #{50 + down} L #{57 - left} 50 Z", fill: "none", stroke: "#e2e8f0", "stroke-width": "0.5", "stroke-dasharray": "2,2" }
                
                %rect{ x: "50", y: "-30", transform: "rotate(45)", width: "50", height: "50", fill: "#fff", "stroke-width": "1", stroke: "#CBD5E0" }
                %line{ x1: "22", y1: "50", x2: "91", y2: "50", "stroke-width": "1", stroke: "#CBD5E0" }
                %line{ x1: "57", y1: "15", x2: "57", y2: "85", "stroke-width": "1", stroke: "#CBD5E0" }
                %path{ fill: "#428BCA4A", "stroke-linecap": "round", "stroke-width": "1", stroke: "#8499B3", d: spider_data[:path_d] }
                
                - cat_f = foops_data[:categories]['Findable'] || {passed: 0, total: 0}
                - cat_a = foops_data[:categories]['Accessible'] || {passed: 0, total: 0}
                - cat_i = foops_data[:categories]['Interoperable'] || {passed: 0, total: 0}
                - cat_r = foops_data[:categories]['Reusable'] || {passed: 0, total: 0}
                
                %text{ x: "10", y: "50", "text-anchor": "end", dy: "7", "font-size": "8" }= "Reusable (#{cat_r[:passed]}/#{cat_r[:total]})"
                %text{ x: "57", y: "0", "text-anchor": "middle", dy: "7", "font-size": "8" }= "Findable (#{cat_f[:passed]}/#{cat_f[:total]})"
                %text{ x: "95", y: "50", "text-anchor": "start", dy: "7", "font-size": "8" }= "Accessible (#{cat_a[:passed]}/#{cat_a[:total]})"
                %text{ x: "57", y: "90", "text-anchor": "middle", dy: "7", "font-size": "8" }= "Interoperable (#{cat_i[:passed]}/#{cat_i[:total]})"

          %style
            :css
              #graphicScore svg, #graphicSpider svg { cursor: pointer; }
              .foops-container { overflow: visible !important; }